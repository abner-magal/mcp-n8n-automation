# ─────────────────────────────────────────────────────────────────────────────
# .dockerignore — mcp-n8n-automation
# WBS-PLAN FASE G.2 — Docker Otimizado
# Exclui tudo exceto o necessário para o build multi-stage
# ─────────────────────────────────────────────────────────────────────────────

# ── Dependências e artefatos de build (instalados/copiados dentro do Docker) ──
node_modules
dist
.tscache
tsconfig.tsbuildinfo
build/
out/

# ── Arquivos de ambiente e segredos ──
.env
.env.local
.env.*
!.env.example

# ── Diretórios de desenvolvimento e teste ──
tests/
test/
coverage/
.nyc_output
test-data/
test-results/
test-summary.md
test-reports/
test-metadata.json

# ── Referências e documentação externa ──
references/
docs/
extracted-nodes/
temp/
tmp/

# ── Git e versionamento ──
.git
.gitignore
.husky
.github

# ── IDE e editores ──
.vscode
.idea
*.swp
*.swo
*~
.eslintcache
.stylelintcache

# ── Sistema operacional ──
.DS_Store
*.log
npm-debug.log
*.bak
*.tmp
*.temp

# ── Docker files (não necessários dentro do build context) ──
Dockerfile*
docker-compose*.yml
.dockerignore
docker/

# ── Scripts de desenvolvimento e deploy ──
scripts/test-*.sh
scripts/deploy-*.sh

# ── N8n docs locais (extraídos, não necessários em produção) ──
../n8n-docs
n8n-docs/

# ── Markdown e textos (exceto README e LICENSE) ──
*.md
!README.md
!LICENSE

# ── Configurações de CI/CD (não usadas no container) ──
codecov.yml
renovate.json

# ── Banco de dados (exceto nodes.db principal) ──
data/*.db-*
!data/nodes.db

# ── YAML de configuração local ──
_config.yml
